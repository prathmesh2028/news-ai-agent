# ─────────────────────────────────────────────
#  .env.example — Copy this to .env and fill in your real values.
#  NEVER commit the real .env file to Git!
# ─────────────────────────────────────────────

# ── Gemini AI ─────────────────────────────────
# Used to summarize news articles with AI.
# Get your free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── NewsAPI ───────────────────────────────────
# Used to fetch the latest news articles.
# Get a free key from: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# How many top articles to fetch per run (recommended: 10-20)
NEWS_MAX_ARTICLES=15

# ── Email — Sender Account ────────────────────
# The Gmail address that SENDS the digest.
EMAIL_ADDRESS=your_gmail_address@gmail.com

# Gmail App Password (NOT your normal Gmail password!).
# How to create one: https://myaccount.google.com/apppasswords
# Requires 2-Factor Authentication to be enabled on your Google account.
EMAIL_PASSWORD=your_16_char_app_password_here

# The address that RECEIVES the digest (can be the same as EMAIL_ADDRESS)
EMAIL_RECIPIENT=recipient@example.com

# ── Email — SMTP Server Settings ──────────────
# SMTP = the protocol used to send emails.
# These settings below are correct for Gmail. Only change if using Outlook etc.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Scheduler ─────────────────────────────────
# Time (24-hour HH:MM format) to send the digest automatically each day.
SEND_TIME=07:00
